# Este ficheiro é lido automaticamente ao arrancar (`import "dotenv/config"`).
# HTTP só para health check (ex.: Kubernetes)
PORT=8787

# URL base do flow-expert (API), sem barra final
FLOW_EXPERT_URL=http://localhost:5173

# Workspace do flow-expert
FLOW_EXPERT_WORKSPACE=default

# Obrigatório se o flow-expert tiver FLOW_EXPERT_AUTH=1 (o mesmo token que emite `flow-expert key issue ...`)
#FLOW_EXPERT_API_KEY=

# Sessão WhatsApp Web (pasta criada pelo whatsapp-web.js / LocalAuth)
WHATSAPP_SESSION_PATH=.wwebjs_auth

# Opcional: binário Chromium (Docker / servidor sem Chrome)
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium

# Opcional: ignorar mensagens de grupos (true = só conversas 1:1)
WHATSAPP_IGNORE_GROUPS=true
