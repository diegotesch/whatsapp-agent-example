# Este ficheiro é sempre carregado a partir da raiz deste pacote (independentemente do CWD), com prioridade sobre variáveis já exportadas no shell.
# HTTP só para health check (ex.: Kubernetes)
PORT=8787

# URL base do flow-expert (API), sem barra final
FLOW_EXPERT_URL=http://localhost:5173

# Workspace do flow-expert
FLOW_EXPERT_WORKSPACE=default

# Obrigatório: Bearer em POST /api/run — chave válida no keystore do projecto apontado por FLOW_EXPERT_URL (pode ser teste, owner, etc.). Não precisa de ser a mesma chave do .env do processo `flow-expert studio`; o agente é um cliente separado.
FLOW_EXPERT_API_KEY=

# Sessão WhatsApp Web (pasta criada pelo whatsapp-web.js / LocalAuth)
WHATSAPP_SESSION_PATH=.wwebjs_auth

# Opcional: binário Chromium (Docker / servidor sem Chrome)
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium

# Opcional: ignorar mensagens de grupos (true = só conversas 1:1)
WHATSAPP_IGNORE_GROUPS=true
